<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eventify Lab - Transformando Eventos em Experiências</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #1a2332;
            --navy-dark: #0f1520;
            --lime: #8bc53f;
            --lime-light: #a4d65e;
            --white: #ffffff;
            --gray-light: #f0f2f5;
            --gray: #6b7280;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--navy-dark);
            color: var(--white);
            overflow-x: hidden;
        }

        /* Animated Background */
        .bg-pattern {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            opacity: 0.03;
            background-image: 
                radial-gradient(circle at 20% 50%, var(--lime) 1px, transparent 1px),
                radial-gradient(circle at 80% 20%, var(--lime) 1px, transparent 1px),
                radial-gradient(circle at 40% 80%, var(--lime) 1px, transparent 1px);
            background-size: 100px 100px, 150px 150px, 200px 200px;
            animation: float 20s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(1deg); }
        }

        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 1.5rem 4rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(to bottom, rgba(15, 21, 32, 0.95), transparent);
            backdrop-filter: blur(10px);
        }

        .logo {
            display: flex;
            align-items: baseline;
            gap: 2px;
        }

        .logo-main {
            font-weight: 800;
            font-size: 1.8rem;
            color: var(--white);
            letter-spacing: -1px;
        }

        .logo-main span {
            color: var(--lime);
        }

        .logo-sub {
            font-family: 'Space Mono', monospace;
            font-size: 0.9rem;
            color: var(--lime);
            margin-left: 4px;
        }

        .nav-links {
            display: flex;
            gap: 3rem;
            list-style: none;
        }

        .nav-links a {
            color: var(--white);
            text-decoration: none;
            font-weight: 400;
            font-size: 0.95rem;
            position: relative;
            transition: color 0.3s ease;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--lime);
            transition: width 0.3s ease;
        }

        .nav-links a:hover {
            color: var(--lime);
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        .btn-contact {
            background: var(--lime);
            color: var(--navy-dark);
            padding: 0.8rem 1.8rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(139, 197, 63, 0.3);
        }

        .btn-contact:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 30px rgba(139, 197, 63, 0.5);
            background: var(--lime-light);
        }

        /* Hero Section */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 8rem 4rem 4rem;
            position: relative;
            z-index: 1;
        }

        .hero-content {
            max-width: 800px;
        }

        .hero-tag {
            font-family: 'Space Mono', monospace;
            color: var(--lime);
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 1.5rem;
            opacity: 0;
            animation: fadeUp 0.8s ease forwards;
            animation-delay: 0.2s;
        }

        .hero h1 {
            font-size: clamp(3rem, 7vw, 5.5rem);
            font-weight: 800;
            line-height: 1.05;
            margin-bottom: 1.5rem;
            opacity: 0;
            animation: fadeUp 0.8s ease forwards;
            animation-delay: 0.4s;
        }

        .hero h1 .highlight {
            color: var(--lime);
            position: relative;
            display: inline-block;
        }

        .hero h1 .highlight::after {
            content: '';
            position: absolute;
            bottom: 0.1em;
            left: 0;
            width: 100%;
            height: 0.15em;
            background: var(--lime);
            opacity: 0.3;
            transform: skewX(-10deg);
        }

        .hero p {
            font-size: 1.25rem;
            color: var(--gray);
            line-height: 1.7;
            max-width: 600px;
            margin-bottom: 2.5rem;
            opacity: 0;
            animation: fadeUp 0.8s ease forwards;
            animation-delay: 0.6s;
        }

        .hero-buttons {
            display: flex;
            gap: 1rem;
            opacity: 0;
            animation: fadeUp 0.8s ease forwards;
            animation-delay: 0.8s;
        }

        .btn-primary {
            background: var(--lime);
            color: var(--navy-dark);
            padding: 1rem 2.5rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 40px rgba(139, 197, 63, 0.4);
        }

        .btn-secondary {
            border: 2px solid rgba(255,255,255,0.2);
            color: var(--white);
            padding: 1rem 2.5rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 500;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .btn-secondary:hover {
            border-color: var(--lime);
            color: var(--lime);
        }

        .hero-visual {
            position: absolute;
            right: 4rem;
            top: 50%;
            transform: translateY(-50%);
            width: 45%;
            height: 70vh;
            opacity: 0;
            animation: fadeIn 1.2s ease forwards;
            animation-delay: 1s;
        }

        .floating-cards {
            position: relative;
            width: 100%;
            height: 100%;
        }

        .floating-card {
            position: absolute;
            background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.05));
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px;
            padding: 2rem;
            animation: floatCard 6s ease-in-out infinite;
        }

        .floating-card:nth-child(1) {
            top: 10%;
            left: 10%;
            width: 280px;
            animation-delay: 0s;
        }

        .floating-card:nth-child(2) {
            top: 35%;
            right: 5%;
            width: 240px;
            animation-delay: 2s;
        }

        .floating-card:nth-child(3) {
            bottom: 15%;
            left: 20%;
            width: 260px;
            animation-delay: 4s;
        }

        @keyframes floatCard {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-15px) rotate(2deg); }
        }

        .card-icon {
            width: 50px;
            height: 50px;
            background: var(--lime);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
            font-size: 1.5rem;
        }

        .card-title {
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .card-text {
            font-size: 0.9rem;
            color: var(--gray);
        }

        /* Services Section */
        .services {
            padding: 8rem 4rem;
            position: relative;
            z-index: 1;
            background: linear-gradient(to bottom, transparent, rgba(139, 197, 63, 0.02), transparent);
        }

        .section-header {
            text-align: center;
            margin-bottom: 5rem;
        }

        .section-tag {
            font-family: 'Space Mono', monospace;
            color: var(--lime);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 1rem;
        }

        .section-title {
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .section-subtitle {
            color: var(--gray);
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto;
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .service-card {
            background: linear-gradient(135deg, rgba(26, 35, 50, 0.8), rgba(26, 35, 50, 0.4));
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 24px;
            padding: 3rem;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }

        .service-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(139, 197, 63, 0.1), transparent);
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .service-card:hover {
            transform: translateY(-10px);
            border-color: rgba(139, 197, 63, 0.3);
        }

        .service-card:hover::before {
            opacity: 1;
        }

        .service-number {
            font-family: 'Space Mono', monospace;
            font-size: 0.75rem;
            color: var(--lime);
            margin-bottom: 1.5rem;
        }

        .service-icon {
            font-size: 3rem;
            margin-bottom: 1.5rem;
        }

        .service-title {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 1rem;
        }

        .service-desc {
            color: var(--gray);
            line-height: 1.7;
        }

        /* Stats Section */
        .stats {
            padding: 6rem 4rem;
            position: relative;
            z-index: 1;
        }

        .stats-container {
            display: flex;
            justify-content: center;
            gap: 6rem;
            flex-wrap: wrap;
        }

        .stat-item {
            text-align: center;
        }

        .stat-number {
            font-size: clamp(3rem, 6vw, 5rem);
            font-weight: 800;
            color: var(--lime);
            line-height: 1;
        }

        .stat-label {
            font-family: 'Space Mono', monospace;
            font-size: 0.85rem;
            color: var(--gray);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-top: 0.5rem;
        }

        /* About Section */
        .about {
            padding: 8rem 4rem;
            position: relative;
            z-index: 1;
        }

        .about-content {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6rem;
            align-items: center;
        }

        .about-text h2 {
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 700;
            margin-bottom: 1.5rem;
        }

        .about-text h2 span {
            color: var(--lime);
        }

        .about-text p {
            color: var(--gray);
            line-height: 1.8;
            margin-bottom: 1.5rem;
            font-size: 1.1rem;
        }

        .about-visual {
            position: relative;
        }

        .about-image {
            width: 100%;
            height: 500px;
            background: linear-gradient(135deg, var(--navy), var(--navy-dark));
            border-radius: 30px;
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.05);
        }

        .about-image::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 200px;
            height: 200px;
            background: var(--lime);
            border-radius: 50%;
            opacity: 0.1;
            animation: pulse 4s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.1; }
            50% { transform: translate(-50%, -50%) scale(1.5); opacity: 0.05; }
        }

        .about-image-content {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
        }

        .about-image-content .icon-large {
            font-size: 5rem;
            margin-bottom: 1rem;
        }

        .about-image-content p {
            font-family: 'Space Mono', monospace;
            font-size: 0.9rem;
            color: var(--lime);
        }

        /* Contact Section */
        .contact {
            padding: 8rem 4rem;
            position: relative;
            z-index: 1;
            background: linear-gradient(to top, rgba(139, 197, 63, 0.05), transparent);
        }

        .contact-container {
            max-width: 800px;
            margin: 0 auto;
            text-align: center;
        }

        .contact h2 {
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 700;
            margin-bottom: 1.5rem;
        }

        .contact p {
            color: var(--gray);
            font-size: 1.2rem;
            margin-bottom: 3rem;
        }

        .contact-buttons {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .contact-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            padding: 1.2rem 2.5rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .contact-btn.email {
            background: var(--lime);
            color: var(--navy-dark);
        }

        .contact-btn.email:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 40px rgba(139, 197, 63, 0.4);
        }

        .contact-btn.whatsapp {
            background: transparent;
            border: 2px solid var(--lime);
            color: var(--lime);
        }

        .contact-btn.whatsapp:hover {
            background: var(--lime);
            color: var(--navy-dark);
        }

        /* Footer */
        footer {
            padding: 4rem;
            border-top: 1px solid rgba(255,255,255,0.05);
            position: relative;
            z-index: 1;
        }

        .footer-content {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 2rem;
        }

        .footer-logo {
            display: flex;
            align-items: baseline;
        }

        .footer-links {
            display: flex;
            gap: 2rem;
        }

        .footer-links a {
            color: var(--gray);
            text-decoration: none;
            font-size: 0.9rem;
            transition: color 0.3s ease;
        }

        .footer-links a:hover {
            color: var(--lime);
        }

        .footer-copy {
            color: var(--gray);
            font-size: 0.85rem;
        }

        /* Animations */
        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .hero-visual {
                display: none;
            }
        }

        @media (max-width: 900px) {
            nav {
                padding: 1rem 2rem;
            }

            .logo-main {
                font-size: 1.4rem;
            }

            .nav-links {
                display: none;
            }

            .btn-contact {
                padding: 0.6rem 1.5rem;
                font-size: 0.8rem;
            }

            .hero {
                padding: 6rem 2rem 4rem;
            }

            .hero h1 {
                font-size: clamp(2rem, 5vw, 4rem);
            }

            .hero p {
                font-size: 1.1rem;
            }

            .services, .about, .contact {
                padding: 6rem 2rem;
            }

            .section-title {
                font-size: clamp(2rem, 4vw, 3rem);
            }

            .about-content {
                grid-template-columns: 1fr;
                gap: 3rem;
            }

            .stats-container {
                gap: 3rem;
            }

            .service-card {
                padding: 2rem;
            }

            .service-icon {
                font-size: 2rem;
            }

            .service-title {
                font-size: 1.2rem;
            }
        }

        @media (max-width: 768px) {
            body {
                font-size: 16px;
            }

            nav {
                padding: 1rem;
            }

            .logo-main {
                font-size: 1.3rem;
            }

            .logo-sub {
                font-size: 0.8rem;
            }

            .btn-contact {
                padding: 0.6rem 1.4rem;
                font-size: 0.85rem;
            }

            .hero {
                min-height: 90vh;
                padding: 5rem 1.5rem 3rem;
            }

            .hero-tag {
                font-size: 0.75rem;
                letter-spacing: 2px;
            }

            .hero h1 {
                font-size: clamp(2rem, 7vw, 3rem);
                margin-bottom: 1.2rem;
            }

            .hero p {
                font-size: 1.1rem;
                margin-bottom: 1.8rem;
            }

            .btn-primary,
            .btn-secondary {
                padding: 0.9rem 2rem;
                font-size: 1rem;
            }

            .services, .about, .contact {
                padding: 5rem 1.5rem;
            }

            .section-header {
                margin-bottom: 3rem;
            }

            .section-tag {
                font-size: 0.75rem;
                letter-spacing: 2px;
            }

            .section-title {
                font-size: clamp(2rem, 5vw, 2.8rem);
                margin-bottom: 1rem;
            }

            .section-subtitle {
                font-size: 1.05rem;
            }

            .services-grid {
                grid-template-columns: 1fr;
                gap: 2rem;
            }

            .service-card {
                padding: 2rem;
            }

            .service-number {
                font-size: 0.7rem;
                margin-bottom: 1rem;
            }

            .service-icon {
                font-size: 2.5rem;
                margin-bottom: 1.2rem;
            }

            .service-title {
                font-size: 1.25rem;
                margin-bottom: 1rem;
            }

            .service-desc {
                font-size: 0.95rem;
                line-height: 1.6;
            }

            .stat-number {
                font-size: clamp(2.5rem, 6vw, 4rem);
            }

            .stat-label {
                font-size: 0.8rem;
                letter-spacing: 1px;
            }

            .about-text h2 {
                font-size: clamp(1.7rem, 5vw, 2.2rem);
                margin-bottom: 1.2rem;
            }

            .about-text p {
                font-size: 1rem;
                margin-bottom: 1.2rem;
            }

            .about-image {
                height: 320px;
            }

            .about-image-content .icon-large {
                font-size: 3.5rem;
                margin-bottom: 0.7rem;
            }

            .contact h2 {
                font-size: clamp(2rem, 5vw, 2.8rem);
                margin-bottom: 1.2rem;
            }

            .contact p {
                font-size: 1.05rem;
                margin-bottom: 2rem;
            }

            .contact-btn {
                padding: 1rem 2rem;
                font-size: 0.95rem;
                gap: 0.6rem;
            }

            footer {
                padding: 2.5rem;
            }

            .footer-content {
                gap: 1.5rem;
            }

            .footer-links {
                gap: 1.5rem;
            }

            .footer-links a {
                font-size: 0.85rem;
            }

            .footer-copy {
                font-size: 0.8rem;
            }
        }

        @media (max-width: 600px) {
            nav {
                padding: 0.9rem;
            }

            .logo-main {
                font-size: 1.1rem;
            }

            .logo-sub {
                font-size: 0.75rem;
            }

            .btn-contact {
                padding: 0.6rem 1.2rem;
                font-size: 0.8rem;
            }

            .hero {
                min-height: 85vh;
                padding: 4.5rem 1.2rem 3rem;
            }

            .hero-tag {
                font-size: 0.7rem;
                margin-bottom: 1.2rem;
            }

            .hero h1 {
                font-size: clamp(1.7rem, 6vw, 2.8rem);
                margin-bottom: 1rem;
                line-height: 1.25;
            }

            .hero p {
                font-size: 0.95rem;
                line-height: 1.7;
                margin-bottom: 1.5rem;
            }

            .hero-buttons {
                flex-direction: column;
                gap: 1rem;
            }

            .btn-primary,
            .btn-secondary {
                padding: 0.85rem 1.8rem;
                font-size: 0.9rem;
                width: 100%;
                justify-content: center;
            }

            .services, .about, .contact {
                padding: 4rem 1.2rem;
            }

            .section-header {
                margin-bottom: 3rem;
            }

            .section-tag {
                font-size: 0.7rem;
                margin-bottom: 1rem;
            }

            .section-title {
                font-size: clamp(1.8rem, 5vw, 2.4rem);
                margin-bottom: 1rem;
            }

            .section-subtitle {
                font-size: 0.98rem;
            }

            .services-grid {
                grid-template-columns: 1fr;
                gap: 1.8rem;
            }

            .service-card {
                padding: 1.8rem;
            }

            .service-number {
                font-size: 0.65rem;
                margin-bottom: 1rem;
            }

            .service-icon {
                font-size: 2.2rem;
                margin-bottom: 1rem;
            }

            .service-title {
                font-size: 1.1rem;
                margin-bottom: 0.8rem;
            }

            .service-desc {
                font-size: 0.9rem;
                line-height: 1.6;
            }

            .stats {
                padding: 4rem 1.2rem;
            }

            .stats-container {
                flex-direction: column;
                gap: 2.5rem;
            }

            .stat-number {
                font-size: clamp(2rem, 5vw, 3.5rem);
            }

            .stat-label {
                font-size: 0.75rem;
                letter-spacing: 1px;
                margin-top: 0.5rem;
            }

            .about-content {
                gap: 2.5rem;
            }

            .about-text h2 {
                font-size: clamp(1.5rem, 4vw, 2rem);
                margin-bottom: 1rem;
            }

            .about-text p {
                font-size: 0.95rem;
                margin-bottom: 1rem;
            }

            .about-image {
                height: 280px;
            }

            .about-image-content .icon-large {
                font-size: 3rem;
                margin-bottom: 0.5rem;
            }

