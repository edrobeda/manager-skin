<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eventify Lab - Transformando Eventos em Experiencias</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: {
                            DEFAULT: '#10b981',
                            light: '#34d399',
                            dark: '#059669'
                        },
                        dark: {
                            DEFAULT: '#0f172a',
                            lighter: '#1e293b',
                            card: '#1a2234'
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <style>
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-15px); }
        }
        .animate-float { animation: float 6s ease-in-out infinite; }
        .animate-float-delay-2 { animation: float 6s ease-in-out infinite 2s; }
        .animate-float-delay-4 { animation: float 6s ease-in-out infinite 4s; }

        @keyframes pulse-glow {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.3); opacity: 0.8; }
        }
        .animate-pulse-glow { animation: pulse-glow 4s ease-in-out infinite; }
    </style>
</head>
<body class="font-sans bg-dark text-white">

    <!-- Navbar -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-dark/90 backdrop-blur-md border-b border-white/5">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <!-- Logo -->
                <a href="/" class="text-xl sm:text-2xl font-extrabold">
                    Eventify<span class="text-primary">Lab</span>
                </a>

                <!-- Desktop Menu -->
                <ul class="hidden md:flex items-center gap-8">
                    <li><a href="#services" class="text-gray-300 hover:text-primary transition-colors text-sm font-medium">Servicos</a></li>
                    <li><a href="#about" class="text-gray-300 hover:text-primary transition-colors text-sm font-medium">Sobre</a></li>
                    <li><a href="#contact" class="text-gray-300 hover:text-primary transition-colors text-sm font-medium">Contato</a></li>
                    <li>
                        <a href="#contact" class="bg-primary hover:bg-primary-light text-dark px-5 py-2.5 rounded-lg font-semibold text-sm transition-all hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary/30">
                            Fale Conosco
                        </a>
                    </li>
                </ul>

                <!-- Mobile Menu Button -->
                <button id="mobile-menu-btn" class="md:hidden text-white text-2xl">
                    &#9776;
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden bg-dark-lighter border-t border-white/5">
            <div class="px-4 py-4 space-y-3">
                <a href="#services" class="block text-gray-300 hover:text-primary py-2">Servicos</a>
                <a href="#about" class="block text-gray-300 hover:text-primary py-2">Sobre</a>
                <a href="#contact" class="block text-gray-300 hover:text-primary py-2">Contato</a>
                <a href="#contact" class="block bg-primary text-dark text-center py-3 rounded-lg font-semibold mt-4">Fale Conosco</a>
            </div>
        </div>
    </nav>

    <!-- Hero -->
    <section class="min-h-screen flex items-center pt-20 pb-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
        <!-- Background Glow -->
        <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-radial from-primary/15 to-transparent pointer-events-none hidden lg:block"></div>

        <div class="max-w-7xl mx-auto w-full">
            <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
                <!-- Content -->
                <div class="text-center lg:text-left order-1">
                    <span class="inline-block px-4 py-2 bg-primary/10 border border-primary/30 rounded-full text-xs sm:text-sm font-semibold text-primary mb-4 sm:mb-6">
                        Inovacao em Eventos
                    </span>

                    <h1 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-extrabold leading-tight mb-4 sm:mb-6">
                        Transformamos
                        <span class="bg-gradient-to-r from-primary to-primary-light bg-clip-text text-transparent">ideias</span>
                        em experiencias memoraveis
                    </h1>

                    <p class="text-gray-400 text-base sm:text-lg mb-6 sm:mb-8 max-w-xl mx-auto lg:mx-0">
                        Somos especialistas em criar eventos unicos que conectam pessoas, marcas e historias. Do conceito a execucao, cada detalhe e pensado para surpreender.
                    </p>

                    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center lg:justify-start">
                        <a href="#contact" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-dark px-6 py-3.5 rounded-lg font-semibold transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-primary/30">
                            Iniciar Projeto
                            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M5 12h14M12 5l7 7-7 7"/>
                            </svg>
                        </a>
                        <a href="#services" class="inline-flex items-center justify-center border-2 border-gray-600 hover:border-primary text-white hover:text-primary px-6 py-3.5 rounded-lg font-medium transition-all">
                            Ver Servicos
                        </a>
                    </div>
                </div>

                <!-- Visual - Hidden on mobile -->
                <div class="hidden lg:block order-2 relative h-[450px]">
                    <div class="absolute top-0 left-0 w-56 bg-dark-card border border-white/10 rounded-2xl p-5 animate-float">
                        <div class="w-12 h-12 bg-gradient-to-br from-primary to-primary-dark rounded-xl flex items-center justify-center text-2xl mb-3">&#127919;</div>
                        <h4 class="font-semibold mb-1">Estrategia</h4>
                        <p class="text-sm text-gray-500">Planejamento personalizado para cada projeto</p>
                    </div>

                    <div class="absolute top-1/3 right-0 w-52 bg-dark-card border border-white/10 rounded-2xl p-5 animate-float-delay-2">
                        <div class="w-12 h-12 bg-gradient-to-br from-primary to-primary-dark rounded-xl flex items-center justify-center text-2xl mb-3">&#10024;</div>
                        <h4 class="font-semibold mb-1">Criatividade</h4>
                        <p class="text-sm text-gray-500">Conceitos unicos que impressionam</p>
                    </div>

                    <div class="absolute bottom-0 left-1/4 w-60 bg-dark-card border border-white/10 rounded-2xl p-5 animate-float-delay-4">
                        <div class="w-12 h-12 bg-gradient-to-br from-primary to-primary-dark rounded-xl flex items-center justify-center text-2xl mb-3">&#128640;</div>
                        <h4 class="font-semibold mb-1">Execucao</h4>
                        <p class="text-sm text-gray-500">Entrega impecavel em cada detalhe</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Services -->
    <section id="services" class="py-16 sm:py-20 lg:py-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-dark via-dark-lighter to-dark">
        <div class="max-w-7xl mx-auto">
            <!-- Header -->
            <div class="text-center mb-10 sm:mb-16">
                <span class="inline-block px-4 py-1.5 bg-primary/10 rounded-full text-xs font-semibold text-primary uppercase tracking-wider mb-3">
                    O que fazemos
                </span>
                <h2 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold mb-3 sm:mb-4">Nossos Servicos</h2>
                <p class="text-gray-400 text-base sm:text-lg max-w-2xl mx-auto">
                    Solucoes interativas que engajam, captam leads e geram resultados
                </p>
            </div>

            <!-- Grid -->
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
                <!-- Card 1 -->
                <div class="group bg-dark-card border border-white/5 rounded-2xl p-5 sm:p-6 transition-all hover:-translate-y-2 hover:border-primary/20 hover:shadow-2xl hover:shadow-black/50 relative overflow-hidden">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary to-primary-light scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
                    <span class="text-xs font-bold text-primary">01</span>
                    <div class="text-4xl my-3">&#127904;</div>
                    <h3 class="text-lg font-bold mb-2">Roleta de Premios</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">Sistema de cadastro + roleta interativa na tela. O participante se cadastra e gira para ganhar brindes na hora.</p>
                </div>

                <!-- Card 2 -->
                <div class="group bg-dark-card border border-white/5 rounded-2xl p-5 sm:p-6 transition-all hover:-translate-y-2 hover:border-primary/20 hover:shadow-2xl hover:shadow-black/50 relative overflow-hidden">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary to-primary-light scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
                    <span class="text-xs font-bold text-primary">02</span>
                    <div class="text-4xl my-3">&#127915;</div>
                    <h3 class="text-lg font-bold mb-2">Sorteios com QR Code</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">Cadastro via QR Code durante o evento e sorteio ao vivo no final. Simples para o participante, poderoso para captar dados.</p>
                </div>

                <!-- Card 3 -->
                <div class="group bg-dark-card border border-white/5 rounded-2xl p-5 sm:p-6 transition-all hover:-translate-y-2 hover:border-primary/20 hover:shadow-2xl hover:shadow-black/50 relative overflow-hidden">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary to-primary-light scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
                    <span class="text-xs font-bold text-primary">03</span>
                    <div class="text-4xl my-3">&#128242;</div>
                    <h3 class="text-lg font-bold mb-2">Captacao de Leads</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">Sistemas de cadastro otimizados que coletam dados do publico e entregam leads quentes direto no WhatsApp.</p>
                </div>

                <!-- Card 4 -->
                <div class="group bg-dark-card border border-white/5 rounded-2xl p-5 sm:p-6 transition-all hover:-translate-y-2 hover:border-primary/20 hover:shadow-2xl hover:shadow-black/50 relative overflow-hidden">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary to-primary-light scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
                    <span class="text-xs font-bold text-primary">04</span>
                    <div class="text-4xl my-3">&#127918;</div>
                    <h3 class="text-lg font-bold mb-2">Ativacoes Gamificadas</h3>
                    <p class="text-sm text-gray-400 leading-relaxed">Transformamos a experiencia do publico em jogo. Dinamicas interativas que criam memorias positivas.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats -->
    <section class="py-12 sm:py-16 px-4 sm:px-6 lg:px-8 border-y border-white/5">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
                <div class="text-center">
                    <div class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-primary">16+</div>
                    <div class="text-xs sm:text-sm text-gray-500 uppercase tracking-wider mt-1">Eventos Realizados</div>
                </div>
                <div class="text-center">
                    <div class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-primary">25k+</div>
                    <div class="text-xs sm:text-sm text-gray-500 uppercase tracking-wider mt-1">Participantes</div>
                </div>
                <div class="text-center">
                    <div class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-primary">25k+</div>
                    <div class="text-xs sm:text-sm text-gray-500 uppercase tracking-wider mt-1">Leads Gerados</div>
                </div>
                <div class="text-center">
                    <div class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-primary">3+</div>
                    <div class="text-xs sm:text-sm text-gray-500 uppercase tracking-wider mt-1">Anos Experiencia</div>
                </div>
            </div>
        </div>
    </section>

    <!-- About -->
    <section id="about" class="py-16 sm:py-20 lg:py-24 px-4 sm:px-6 lg:px-8">
        <div class="max-w-7xl mx-auto">
            <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
                <!-- Content -->
                <div class="order-2 lg:order-1">
                    <h2 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold mb-4 sm:mb-6">
                        Por que escolher a <span class="text-primary">Eventify Lab</span>?
                    </h2>
                    <div class="space-y-4 text-gray-400 text-base sm:text-lg">
                        <p>Nascemos da paixao por criar momentos inesqueciveis. Nossa equipe combina criatividade, tecnologia e expertise em gestao para entregar eventos que superam expectativas.</p>
                        <p>Cada projeto e um laboratorio de ideias onde experimentamos, inovamos e criamos experiencias unicas. Do briefing ao pos-evento, acompanhamos cada etapa com dedicacao total.</p>
                        <p>Acreditamos que eventos sao pontes que conectam pessoas, marcas e historias. E nos construimos essas pontes com excelencia.</p>
                    </div>
                </div>

                <!-- Visual -->
                <div class="order-1 lg:order-2">
                    <div class="bg-gradient-to-br from-dark-card to-dark-lighter border border-white/10 rounded-3xl h-64 sm:h-80 lg:h-96 flex flex-col items-center justify-center relative overflow-hidden">
                        <div class="absolute w-48 h-48 bg-primary/20 rounded-full animate-pulse-glow"></div>
                        <div class="text-5xl sm:text-6xl relative z-10">&#128300;</div>
                        <span class="text-primary font-semibold mt-3 relative z-10 text-sm sm:text-base">Laboratorio de experiencias</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="py-16 sm:py-20 lg:py-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-t from-primary/5 to-transparent">
        <div class="max-w-2xl mx-auto text-center">
            <span class="inline-block px-4 py-1.5 bg-primary/10 rounded-full text-xs font-semibold text-primary uppercase tracking-wider mb-3">
                Vamos conversar
            </span>
            <h2 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold mb-3 sm:mb-4">
                Pronto para criar algo incrivel?
            </h2>
            <p class="text-gray-400 text-base sm:text-lg mb-6 sm:mb-8">
                Entre em contato e vamos transformar sua ideia em um evento memoravel.
            </p>

            <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
                <a href="mailto:divulgacao@eventifylab.com.br" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-dark px-6 py-3.5 rounded-lg font-semibold transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-primary/30">
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                        <polyline points="22,6 12,13 2,6"/>
                    </svg>
                    Enviar E-mail
                </a>
                <a href="https://wa.me/5519981442580?text=Gostaria de mais informações sobre EventifyLab." class="inline-flex items-center justify-center gap-2 border-2 border-primary text-primary hover:bg-primary hover:text-dark px-6 py-3.5 rounded-lg font-semibold transition-all">
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                    WhatsApp
                </a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="py-8 sm:py-10 px-4 sm:px-6 lg:px-8 border-t border-white/5">
        <div class="max-w-7xl mx-auto">
            <div class="flex flex-col sm:flex-row justify-between items-center gap-6">
                <a href="/" class="text-xl font-extrabold">
                    Eventify<span class="text-primary">Lab</span>
                </a>

                <div class="flex flex-wrap justify-center gap-4 sm:gap-6">
                    <a href="#services" class="text-gray-500 hover:text-primary text-sm transition-colors">Servicos</a>
                    <a href="#about" class="text-gray-500 hover:text-primary text-sm transition-colors">Sobre</a>
                    <a href="#contact" class="text-gray-500 hover:text-primary text-sm transition-colors">Contato</a>
                    <a href="#" class="text-gray-500 hover:text-primary text-sm transition-colors">Instagram</a>
                    <a href="#" class="text-gray-500 hover:text-primary text-sm transition-colors">LinkedIn</a>
                </div>

                <p class="text-gray-500 text-xs sm:text-sm">
                    &copy; 2026 Eventify Lab. Todos os direitos reservados.
                </p>
            </div>
        </div>
    </footer>

    <!-- Mobile Menu Script -->
    <script>
        const menuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');

        menuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });

        // Close menu when clicking a link
        mobileMenu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.add('hidden');
            });
        });
    </script>
</body>
</html>
